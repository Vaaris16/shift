{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "shift",
  "version": "0.1.0",
  "identifier": "com.vaarischitkara.shift",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "shift",
        "width": 700,
        "height": 500,
        "resizable": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$DOWNLOAD/**", "$HOME/**"]
      }
    }
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "windows": {
        "installMode": "passive"
      },
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM2RjJGQzU1NUZGMEYzQTkKUldTcDgvQmZWZnp5TnUyd0lYemNRbVdpU0I1bGRiOXJWLzJoYkUrZENremdDditBb0dOQTAzMzEK",
      "endpoints": [
        "https://github.com/Vaaris16/shift/releases/latest/download/latest.json"
        ]
    }
  }
}
